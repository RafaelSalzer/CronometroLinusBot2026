#:kivy 2.1.0
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton

<MainWidget>:
    md_bg_color: "#28519e"
    orientation: 'vertical'
    
    MDBoxLayout:
        orientation: 'vertical'
        
        # Espaço Sueprior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 10
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"
        
        # Linha Amarela
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#d3a613"

        # Linha Verde
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#439c48"

        # Espaço para o título
        MDBoxLayout:
            orientation: 'horizontal'
            size: 1920, 100
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"

            # Texto para cada equipe
            MDLabel:
                text: "EQUIPE COR: FLU CRAQUE RAFA"
                id: tituloEquipe
                halign: "center"
                valign: "middle"
                font_size: "70sp"
                font_name: "Titulo"
                text_color: "#fcc425"

        # Linha Amarela Inferior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#d3a613"

        # Linha Verde Inferior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#439c48"
        
        # Espaço Inferior (Depois do título)
        MDBoxLayout:
            orientation: 'horizontal'
            size: 1920, 150
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"
