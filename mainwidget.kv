#:kivy 2.1.0
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton

<MainWidget>:
    md_bg_color: "#28519e"
    orientation: 'vertical'
    
    MDBoxLayout:
        orientation: 'vertical'
        
        # Parte da Barra Superior ----------------------------------------------------------

        # Espaço Sueprior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 10
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"
        
        # Linha Amarela
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#d3a613"

        # Linha Verde
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#439c48"

        # Espaço para o título
        MDBoxLayout:
            orientation: 'horizontal'
            size: 1920, 100
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"

            # Texto para cada equipe
            MDLabel:
                text: "EQUIPE COR: FLU CRAQUE RAFA"
                id: tituloEquipe
                halign: "center"
                valign: "middle"
                font_size: "70sp"
                font_name: "fonts/Lovelo Black.otf"
                text_color: "#fcc425"

        # Linha Amarela Inferior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#d3a613"

        # Linha Verde Inferior
        MDBoxLayout:
            orientation: 'vertical'
            size: 1920, 7
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#439c48"
        
        # Parte do Cronômetro (Tempo Total) -----------------------------------------------------------------

        # Espaço Inferior (Depois do título)
        MDBoxLayout:
            orientation: 'horizontal'
            size: 1920, 150
            size_hint: None, None  # Desabilita o redimensionamento automático
            pos_hint: {'top': 1, 'center_x': 0.5}  # Posiciona na borda superior
            md_bg_color: "#28519e"

            # Texto para o Tempo Total
            MDLabel:
                text: "Tempo Total:"
                valign: "center"
                halign: "center"
                font_size: "30sp"
                font_name: "fonts/Lovelo Black.otf"

            # Texto para o Tempo Total
            MDLabel:
                text: "00:00.000"
                id: tempoTotal
                valign: "center"
                halign: "center"
                font_size: "80sp"
                font_name: "Roboto"  # Usando a fonte digital

            # Texto para o Tempo da Volta
            MDLabel:
                text: "Tempo da volta:"
                valign: "center"
                halign: "center"
                font_size: "30sp"
                font_name: "fonts/Lovelo Black.otf"

            # Texto para o Tempo da Volta
            MDLabel:
                text: "00:00.000"
                id: tempoVolta
                valign: "center"
                halign: "center"
                font_size: "80sp"
                font_name: "Roboto"

        # Área principal do cronômetro --------------------------------------------------------------

        # Área total restante
        MDBoxLayout:
            orientation: 'horizontal'
            md_bg_color: "#28519e"
            # Este layout vai ocupar o espaço restante automaticamente
            padding: [10, 10, 10, 10]  # [esquerda, topo, direita, baixo]
            spacing: 10  # Espaçamento entre os elementos

            # Espaço para a câmera
            MDBoxLayout:
                orientation: 'vertical'
                size: 1366, 768  # largura: 1600px, altura: 900px
                size_hint: None, None  # Desabilita o redimensionamento automático
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}  # Centraliza o layout
                md_bg_color: "#d3a613"  # Cor de fundo branca

            # Espaço para registro das voltas 
            MDBoxLayout:
                orientation: 'vertical'
                md_bg_color: "#28519e"
                padding: [0, 0, 0, 10]

                # Título para as voltas
                MDLabel:
                    text: "VOLTAS:"
                    valign: "top"
                    halign: "center"
                    font_size: "40sp"
                    font_name: "fonts/Lovelo Black.otf"

                # Texto para cada volta (5 voltas)
                MDLabel:
                    text: "volta 1: 00:00.000"
                    id: volta1
                    valign: "top"
                    halign: "center"
                    font_size: "30sp"
                    font_name: "fonts/Lovelo Black.otf"
                    opacity: 1

                MDLabel:
                    text: "volta 2: 00:00.000"
                    id: volta2
                    valign: "top"
                    halign: "center"
                    font_size: "30sp"
                    font_name: "fonts/Lovelo Black.otf"
                    opacity: 1

                MDLabel:
                    text: "volta 3: 00:00.000"
                    id: volta3
                    valign: "top"
                    halign: "center"
                    font_size: "30sp"
                    font_name: "fonts/Lovelo Black.otf"
                    opacity: 1

                MDLabel:
                    text: "volta 4: 00:00.000"
                    id: volta4
                    valign: "top"
                    halign: "center"
                    font_size: "30sp"
                    font_name: "fonts/Lovelo Black.otf"
                    opacity: 1

                MDLabel:
                    text: "volta 5: 00:00.000"
                    id: volta5
                    valign: "top"
                    halign: "center"
                    font_size: "30sp"
                    font_name: "fonts/Lovelo Black.otf"
                    opacity: 1

                # Espaço para os botões e para o logo
                MDBoxLayout:
                    orientation: 'vertical'
                    md_bg_color: "#28519e"
                    height: 400
                    size_hint_y: None
                    size_hint_x: 1
                    
                    # Logo do Linus
                    Image:
                        source: "images/LogoLinus.png"   
                        keep_ratio: True

                    # Espaço para os botões
                    MDBoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: "60dp"  # Aumentei de 50dp para 80dp
                        md_bg_color: "#439c48"
                        spacing: 5
                        padding: [5, 5, 5, 5]
                        
                        # Botão para reiniciar o cronômetro da volta
                        MDIconButton:
                            icon: "restart"
                            style: "filled"
                            id: botaoRestart
                            on_press: root.zerar_cronometro_volta()
                            theme_bg_color: "Custom"
                            md_bg_color: "#d3a613"
                            theme_icon_color: "Custom"
                            icon_color: "#439c48"
                            size_hint_x: 1  # Distribui igualmente
                            pos_hint: {'center_y': 0.5}

                        # Botão para zerar tudo (cronômetro total e cronômetro da volta)
                        MDIconButton:
                            icon: "cancel"
                            style: "filled"
                            id: botaoCancelar
                            on_press: root.zerar_cronometro()  # Chama o método para zerar o cronômetro
                            theme_bg_color: "Custom"
                            md_bg_color: "#d3a613"
                            theme_icon_color: "Custom"
                            icon_color: "#439c48"
                            size_hint_x: 1  # Distribui igualmente
                            pos_hint: {'center_y': 0.5}

                        # Botão para mover para esquerda
                        MDIconButton:
                            icon: "arrow-left"
                            style: "filled"
                            id: botaoEsquerda
                            theme_bg_color: "Custom"
                            md_bg_color: "#d3a613"
                            theme_icon_color: "Custom"
                            icon_color: "#439c48"
                            size_hint_x: 1  # Distribui igualmente
                            pos_hint: {'center_y': 0.5}
                            on_press: root.selecionar_equipe_esquerda()

                        # Botão home
                        MDIconButton:
                            icon: "home"
                            style: "filled"
                            id: botaoCasa
                            theme_bg_color: "Custom"
                            md_bg_color: "#d3a613"
                            theme_icon_color: "Custom"
                            icon_color: "#439c48"
                            size_hint_x: 1  # Distribui igualmente
                            pos_hint: {'center_y': 0.5}

                        # Botão para mover para direita
                        MDIconButton:
                            icon: "arrow-right"
                            style: "filled"
                            id: botaoDireita
                            theme_bg_color: "Custom"
                            md_bg_color: "#d3a613"
                            theme_icon_color: "Custom"
                            icon_color: "#439c48"
                            size_hint_x: 1  # Distribui igualmente
                            pos_hint: {'center_y': 0.5}
                            on_press: root.selecionar_equipe_direita()
                        
                        